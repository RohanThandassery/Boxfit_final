function estimateAdditionalFits(item, carData, gen, passengers) {
  const trialLoadout = {...loadout};
  const maxTrials = 80;
  let count = 0;

  while (count < maxTrials) {
    trialLoadout[item.id] = (trialLoadout[item.id] || 0) + 1;
    const trial = processLoadout(carData, gen, passengers, trialLoadout);
    if (trial.failedItems.length > 0) break;
    count++;
  }

  return count;
}

