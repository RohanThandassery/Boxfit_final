  .pwc-override input[type="number"]:focus { border-color: var(--orange); }
  .pwc-override input[type="number"]::-webkit-outer-spin-button,
  .pwc-override input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .pwc-unit { font-family: var(--mono); font-size: 0.7rem; color: var(--muted); letter-spacing: 0.06em; }
  #pl-weight-reset {
    background: transparent; border: 1px solid var(--border); color: var(--muted);
    font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.08em; padding: 0.4rem 0.7rem;
    cursor: pointer; border-radius: 3px; transition: all 0.15s; text-transform: uppercase;
  }
  #pl-weight-reset:hover { border-color: var(--orange); color: var(--orange); }
  #pl-weight-reset[disabled] { opacity: 0.3; cursor: not-allowed; pointer-events: none; }

