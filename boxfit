// ===== PAYLOAD / FUEL ECONOMY ENGINE =====
// === DYNAMIC POWERTRAIN PAYLOAD PENALTY ===
// Fractional highway economy/range loss per 100 lb of payload.
const POWERTRAIN_PAYLOAD_LOSS_PER_100LB = {
  ICE: 0.015,
  HEV: 0.012,
  PHEV: 0.012,
  BEV: 0.018
};

const DEFAULT_GAS_PRICE = 3.50;        // USD/gal — AAA national average regular
const DEFAULT_TRIP_MILES = 500;
const MIN_TRIP_MILES = 25;
const MAX_TRIP_MILES = 2000;

function getVehicleSubType(carData, gen) {
  if (carData.subType) return carData.subType;
  if (carData.class === 'truck') return 'Full-Size Truck';
  if (carData.class === 'hatchback') return 'Compact Hatchback';
  if (carData.class === 'sedan') return gen.cargo_vol_cuft >= 15 ? 'Midsize Sedan' : 'Compact Sedan';
  if (carData.class === 'suv') {
    if (carData.seats >= 7) return '3-Row SUV';
    if (gen.cargo_vol_cuft >= 32) return 'Midsize SUV';
    return 'Compact SUV';
  }
  return 'Midsize Sedan';
}

function parseMpgRange(raw) {
  if (!raw) return { mpg: null, isMPGe: false, raw: null };
  const isMPGe = /MPGe/i.test(raw);
  const nums = raw.match(/\d+(\.\d+)?/g);
  if (!nums || nums.length === 0) return { mpg: null, isMPGe, raw };
  const vals = nums.map(Number);
  const avg = vals.reduce((a,b) => a+b, 0) / vals.length;
  return { mpg: avg, isMPGe, raw };
}

function getSelectedPowertrain(make, model) {
  const pts = VEHICLE_DATABASE[make]?.[model]?.powertrains || [];
  if (!pts.length) return null;
  if (state.powertrainIndex === '' || state.powertrainIndex === null || state.powertrainIndex === undefined) {
    const avgMpg = pts.reduce((sum, pt) => sum + pt.highway_mpg_est, 0) / pts.length;
    const cats = Array.from(new Set(pts.map(pt => pt.powertrain_category)));
    const category = cats.length === 1 ? cats[0] : 'MIXED';
    return {
      engine_type: 'Model average',
      drivetrain: Array.from(new Set(pts.map(pt => pt.drivetrain))).join(' / '),
      powertrain_category: category,
      highway_mpg_est: avgMpg,
      isAverage: true
    };
  }
  const ix = Number(state.powertrainIndex);
  if (Number.isInteger(ix) && ix >= 0 && ix < pts.length) return pts[ix];
  state.powertrainIndex = '';
  return getSelectedPowertrain(make, model);
}

function getPayloadCoefficient(powertrain) {
  if (powertrain?.isAverage && state.make && state.model) {
    const pts = VEHICLE_DATABASE[state.make]?.[state.model]?.powertrains || [];
    if (pts.length) {
      return pts.reduce((sum, pt) => sum + (POWERTRAIN_PAYLOAD_LOSS_PER_100LB[pt.powertrain_category] ?? POWERTRAIN_PAYLOAD_LOSS_PER_100LB.ICE), 0) / pts.length;
    }
  }
  return POWERTRAIN_PAYLOAD_LOSS_PER_100LB[powertrain?.powertrain_category] ?? POWERTRAIN_PAYLOAD_LOSS_PER_100LB.ICE;
}

function getBaseMpg(make, model, carData, gen) {
  const pt = getSelectedPowertrain(make, model);
  if (pt) {
    return {
      mpg: pt.highway_mpg_est,
      isMPGe: pt.powertrain_category === 'BEV',
      raw: `${pt.highway_mpg_est}${pt.powertrain_category === 'BEV' ? ' MPGe' : ''}`,
      powertrain: pt
    };
  }
  const entry = MPG_DATABASE[make]?.[model];
  if (entry) return parseMpgRange(entry);
  const fb = FALLBACK_MPG_BY_SUBTYPE[getVehicleSubType(carData, gen)] ?? 28;
  return { mpg: fb, isMPGe: false, raw: `${fb} (est.)` };
}

function getTankSize(carData, gen) {
  return TANK_BY_SUBTYPE[getVehicleSubType(carData, gen)] ?? 16;
}

function calcPayloadWeight(loadoutSource) {
  let total = 0;
  for (const id in loadoutSource) {
    const qty = loadoutSource[id];
    if (!qty) continue;
    const item = ITEMS.find(i => i.id === id);
    if (item?.weight) total += item.weight * qty;
  }
  return total;
}

function getCurbWeight(carData, gen) {
  if (gen?.curb_weight_lb) return gen.curb_weight_lb;
  if (carData?.curb_weight_lb) return carData.curb_weight_lb;
  return CURB_WEIGHT_FALLBACK_BY_SUBTYPE[getVehicleSubType(carData, gen)] ?? 3500;
}

// Powertrain-sensitive payload-penalty engine.
//   mpgLossFrac = payload/100 × category coefficient
//   ICE 1.5%, HEV/PHEV 1.2%, BEV 1.8% per 100 lb.
function calcRangeImpact(baseMpg, tankGal, payloadLb, curbWeightLb, coefficientPer100Lb) {
  const massIncreaseFrac = curbWeightLb > 0 ? payloadLb / curbWeightLb : 0;
  const coeff = coefficientPer100Lb ?? POWERTRAIN_PAYLOAD_LOSS_PER_100LB.ICE;
  const mpgLossFrac = Math.max(0, (payloadLb / 100) * coeff);
  const adjustedMpg = Math.max(0, baseMpg * (1 - mpgLossFrac));
  return {
    baseRange: baseMpg * tankGal,
    adjustedRange: adjustedMpg * tankGal,
    baseMpg, adjustedMpg,
    massIncreasePct: massIncreaseFrac * 100,
    penaltyPct: mpgLossFrac * 100,
    coefficientPer100Lb: coeff,
    payloadLb, curbWeightLb
  };
}

function calcTripCost(mpg, miles, pricePerGal) {
  if (!mpg || mpg <= 0) return 0;
  return (miles / mpg) * pricePerGal;
}

// ===== STATE =====
let loadout = {};
let state = { make: null, model: null, year: null, passengers: null, powertrainIndex: '' };
// User overrides for the payload/range/cost section.
let weightOverrideLb = null;        // null = use estimated payload
let tripMiles = DEFAULT_TRIP_MILES; // user-controllable via slider
