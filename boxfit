// MASTER UPDATE LOOP
function tryUpdate() {
  const overlay = document.getElementById('awaiting-overlay');
  const overlayMsg = document.getElementById('awaiting-msg');
  const badge = document.getElementById('inline-status');
  
  if (!state.make || !state.model || !state.year || !state.passengers) {
    overlay.style.display = 'flex';
    overlayMsg.textContent = "PLEASE SELECT A VEHICLE MAKE AND MODEL";
    badge.style.display = 'block';
    badge.className = 'loadout-status-badge badge-neutral';
    badge.textContent = "AWAITING CAR SELECTION";
    activeCarData = null;
    activeGeneration = null;
    activeResults = null;
    return; 
  }

  overlay.style.display = 'none';

  const carData = VEHICLE_DATABASE[state.make][state.model];
  const gen = carData.generations.find(g => g.years.includes(state.year)) || carData.generations[carData.generations.length - 1];
  const totalQty = Object.values(loadout).reduce((a,b)=>a+b, 0);
  activeCarData = carData;
  activeGeneration = gen;
  
  let results;
  try {
    results = processLoadout(carData, gen, state.passengers);
    activeResults = results;
  } catch (e) {
    console.error("Critical Math Error:", e);
    overlayMsg.textContent = "MATHEMATICAL ERROR OCCURRED";
    overlay.style.display = 'flex';
    activeResults = null;
    return;
  }

  const totalPhysCap = results.trunkCap + results.foldCap + results.seatCap + results.footCap;
  const isFit = results.failedItems.length === 0;
  const isVolumeOver = results.requestedVol > totalPhysCap + 0.01;
  const isSpatialMisfit = !isFit && !isVolumeOver;

  badge.className = 'loadout-status-badge ' + (isFit ? 'badge-fit' : (isSpatialMisfit ? 'badge-spatial' : 'badge-over'));
  badge.textContent = totalQty === 0 ? 'VEHICLE READY' : (isFit ? '✓ FITS IN VEHICLE' : (isSpatialMisfit ? '⚠ SPATIAL MISFIT' : '✗ OVER CAPACITY'));

  document.getElementById('r-car-name').textContent = `${state.year} ${state.make} ${state.model}`;
  document.getElementById('r-car-sub').textContent = `${carData.class.toUpperCase()} · ${state.passengers} Passenger${state.passengers>1?'s':''}`;
  document.getElementById('r-cargo-space').textContent = results.isTruck
    ? `${totalPhysCap.toFixed(1)} cu ft · ${Math.round(results.carH)}" bed H · ${Math.round(results.rearHeadrestH)}" headrest`
    : `${totalPhysCap.toFixed(1)} cu ft · ${Math.round(results.carH)}" cargo H · ${Math.round(results.rearHeadrestH)}" rear headrest`;

  const bd = document.getElementById('r-breakdown'); bd.innerHTML = '';
  function addBar(lbl, used, max, unit, barClass) {
    if (max <= 0) return;
    const pct = Math.min(100, (used/max)*100).toFixed(1);
    const row = document.createElement('div'); row.className = 'breakdown-row';
    row.innerHTML = `<div class="bar-header"><span>${lbl}</span><span>${used.toFixed(1)} / ${max.toFixed(1)} ${unit} (${pct}%)</span></div><div class="breakdown-bar-wrap ${isSpatialMisfit ? 'warn' : ''}"><div class="breakdown-bar ${barClass}" style="width:${pct}%"></div></div>`;
    bd.appendChild(row);
  }

  addBar(results.isTruck ? 'Pickup Bed Capacity' : 'Trunk Capacity', results.trunkUsedVol, results.trunkCap, 'cu ft', '');
  if(results.foldCap > 0) addBar('Folded Capacity', results.foldUsedVol, results.foldCap, 'cu ft', 'bar-fold');
  if(results.seatCap > 0 || results.footCap > 0) {
     addBar('Seat Loading', results.seatUsedVol, results.seatCap, 'cu ft', 'bar-seats');
     addBar('Footwell Loading', results.footUsedVol, results.footCap, 'cu ft', 'bar-foot');
  }

  const spareContainer = document.getElementById('r-spare-room'); spareContainer.innerHTML = '';
  if (!isFit) {
    const failed = Array.from(new Set(results.failedItems.map(i => `${i.name} (${itemDimsLabel(i)})`))).join(', ');
    const reason = isSpatialMisfit
      ? 'The remaining volume bars are not full because the failed item cannot be placed inside the available width, depth, height, seat, footwell, or stack geometry.'
      : 'The requested item volume is greater than the available physical cargo volume.';
    spareContainer.innerHTML = `<div class="fit-alert"><div class="fit-alert-title">${isSpatialMisfit ? 'SPATIAL MISFIT' : 'OVER CAPACITY'}</div><div class="fit-alert-copy">${reason}<br>Unplaced: ${failed}</div></div>`;
  }
  if (isFit) {
    let remainVol = (results.trunkCap + results.foldCap + results.seatCap + results.footCap) - (results.trunkUsedVol + results.foldUsedVol + results.seatUsedVol + results.footUsedVol);
    let spareHTML = '';
    ITEMS.forEach(item => {
      if (item.group) return;
      if (Math.min(item.w, item.h, item.d) > Math.max(results.carH, results.frontHeadrestH, results.rearHeadrestH)) return;
      const fitsBy3D = estimateAdditionalFits(item, carData, gen, state.passengers);
      if (fitsBy3D > 0) {
        spareHTML += `<div class="spare-chip"><b>+${fitsBy3D}</b> ${item.name}</div>`;
      }
    });
    if (spareHTML !== '') spareContainer.innerHTML = `<div class="spare-room-container"><div class="spare-room-title">✓ ROOM TO SPARE</div><div class="spare-room-desc">You have <b>${remainVol.toFixed(1)} cu ft</b> of total physical space left. The 3D packer can still place:</div><div class="spare-chips">${spareHTML}</div></div>`;
  }

  const stats = document.getElementById('r-stats'); stats.innerHTML = '';
  const foldNote = carData.foldable_rear ? (results.foldBlocked ? 'PASSENGER BLOCKED' : (state.passengers <= carData.seats - 3 ? 'FULLY AVAILABLE' : 'PARTIAL')) : 'SEATS FIXED';
  const stackedItems = results.placed3D.filter(item => {
    const zone = results.zones.find(z => z.name === item.zoneName);
    return zone && item.y > zone.y + 0.5;
  });
  const maxStackHeight = results.placed3D.reduce((max, item) => Math.max(max, item.y + item.packH), 0);
  
  let analysisNotes = [
    `Cargo envelope: ${Math.round(results.carW)}" W x ${Math.round(results.carH)}" H x ${Math.round(results.trunkD)}" D ${results.isTruck ? 'pickup bed' : 'rear cargo area'}.`,
    `Math uses a 1-inch 3D grid height map. Items are rotated and stacked vertically when width, depth, tunnel-limited footwell lanes, and buffered headrest height allow it.`,
    stackedItems.length ? `Vertical stacking shown: ${stackedItems.length} item${stackedItems.length>1?'s':''} placed above floor level; tallest loaded point is ${Math.round(maxStackHeight)}".` : 'Vertical stacking checked: no item needed to sit on top of another for this loadout.',
    results.tunnelWidth > 0 ? `Footwell lanes subtract a ${results.tunnelWidth.toFixed(1)}" transmission tunnel before testing box width across the rear floor.` : 'Footwell lane model uses a flat floor; no transmission tunnel width is subtracted.',
    `Seat/deck zones reserve a ${results.headrestSeatbackBuffer.toFixed(1)}" Z-axis headrest buffer near the seatback before stacking.`,
    results.thirdRowFootwellCount > 0 ? `Three-row model adds ${results.thirdRowFootwellCount} tunnel-aware third-row footwell zone${results.thirdRowFootwellCount>1?'s':''} below the folded deck, estimated from rear legroom and constrained by the same tunnel width/height rules.` : null,
    results.isFolded ? `Folded-seat model includes a ${Math.round(results.seatHeight)}" high below-deck footwell layer plus stackable cargo on top of the folded seat deck up to the ${Math.round(results.rearHeadrestH)}" rear headrest line.` : null,
    results.isTruck ? `Pickup view includes a ${Math.round(results.truckRearCabinD)}" rear cabin row plus the front row, with ${Math.round(results.carH)}" bed height and ${Math.round(results.rearHeadrestH)}" rear/front headrest limits.` : null,
    !isFit ? `${isSpatialMisfit ? 'SPATIAL MISFIT' : 'OVER CAPACITY'}: The vehicle physically cannot fit ${Array.from(new Set(results.failedItems.map(i=>i.name))).join(', ')}.` : null
  ].filter(Boolean);
  
  [
    ['ITEMS FITTED', totalQty === 0 ? "EMPTY" : `${results.itemsPlaced} of ${totalQty}`, isFit ? 'var(--green)' : 'var(--red)'],
    ['TOTAL VOL.', `${totalPhysCap.toFixed(1)} cu ft`, ''],
    [results.isTruck ? 'BED HEIGHT' : 'CARGO HEIGHT', `${Math.round(results.carH)} in`, ''],
    ['REAR HEADREST', `${Math.round(results.rearHeadrestH)} in`, ''],
    ['TUNNEL WIDTH', `${results.tunnelWidth.toFixed(1)} in`, ''],
    ['HEADREST BUFFER', `${results.headrestSeatbackBuffer.toFixed(1)} in`, ''],
    ...(state.passengers === 1 ? [['FRONT HEADREST', `${Math.round(results.frontHeadrestH)} in`, '']] : []),
    ['CARGO FOOTPRINT', `${Math.round(results.carW)}" W x ${Math.round(results.trunkD)}" D`, ''],
    ['FOLD-FLAT', foldNote, carData.foldable_rear ? 'orange' : ''],
    ['MAX PASSENGERS', `${carData.seats}`, '']
  ].forEach(([l,v,c]) => {
    const el = document.createElement('div'); el.className = 'stat-cell';
    el.innerHTML = `<div class="stat-cell-label">${l}</div><div class="stat-cell-val" style="color:${c||'var(--text)'}">${v}</div>`;
    stats.appendChild(el);
  });

  const notes = document.getElementById('r-notes'); notes.innerHTML = '';
  analysisNotes.forEach(m => { const li = document.createElement('li'); li.textContent = m; notes.appendChild(li); });

  updatePayloadAndRange(carData, gen);

  clearTimeout(drawSceneTimer);
  drawSceneTimer = setTimeout(() => { drawScene(results); }, 10);
}

function refreshPayloadOnly() {
  if (!activeCarData || !activeGeneration || !state.make || !state.model || !state.year || !state.passengers) return false;
  updatePayloadAndRange(activeCarData, activeGeneration);
  return true;
}

function updatePayloadAndRange(carData, gen) {
  // Estimated payload from loadout vs. user override.
  const estimatedWeight = calcPayloadWeight(loadout);
  const isCustom = weightOverrideLb !== null && Number.isFinite(weightOverrideLb);
  const totalWeight = isCustom ? weightOverrideLb : estimatedWeight;

  // Per-item breakdown line.
  const parts = [];
  for (const id in loadout) {
    const qty = loadout[id];
    if (!qty) continue;
    const item = ITEMS.find(i => i.id === id);
    if (!item) continue;
    parts.push(`<b>${qty}</b>× ${item.name} (${qty * item.weight} lb)`);
  }
  const breakdownLine = parts.length
    ? parts.join(' &nbsp;·&nbsp; ')
    : 'No items loaded — vehicle is empty.';

  document.getElementById('pl-weight').innerHTML =
    `${Math.round(totalWeight).toLocaleString()} <small>LBS</small>`;

  const modeEl = document.getElementById('pl-weight-mode');
  if (isCustom) {
    modeEl.textContent = `· custom override (estimate was ${estimatedWeight.toLocaleString()} lb)`;
    modeEl.classList.add('custom');
  } else {
    modeEl.textContent = '· estimated from loadout';
    modeEl.classList.remove('custom');
  }
  document.getElementById('pl-breakdown').innerHTML = breakdownLine;

  // Sync override input + reset button state without firing change events.
  const inputEl = document.getElementById('pl-weight-input');
  const resetEl = document.getElementById('pl-weight-reset');
  if (document.activeElement !== inputEl) {
    inputEl.value = isCustom ? weightOverrideLb : '';
    inputEl.placeholder = `est. ${estimatedWeight}`;
  }
  resetEl.disabled = !isCustom;

  // MPG / tank / curb-weight lookup.
  const mpgInfo = getBaseMpg(state.make, state.model, carData, gen);
  const tankGal = getTankSize(carData, gen);
  const curbLb = getCurbWeight(carData, gen);
  const subType = getVehicleSubType(carData, gen);
  const selectedPowertrain = mpgInfo.powertrain || null;
  const drivetrain = selectedPowertrain?.drivetrain || carData.drivetrain || '—';
  const transmission = selectedPowertrain?.engine_type || carData.transmission || '—';
  const powertrainCategory = selectedPowertrain?.powertrain_category || (mpgInfo.isMPGe ? 'BEV' : 'ICE');
  const payloadCoeff = getPayloadCoefficient(selectedPowertrain || { powertrain_category: powertrainCategory });

  if (!mpgInfo.mpg) {
    document.getElementById('pl-range-summary').innerHTML =
      '<b class="warn">No MPG data available for this vehicle</b>';
    return;
  }

  // Road-load weight penalty.
  const range = calcRangeImpact(mpgInfo.mpg, tankGal, totalWeight, curbLb, payloadCoeff);
  const lostMiles = range.baseRange - range.adjustedRange;
  const unit = mpgInfo.isMPGe ? 'MPGe' : 'MPG';
  const distUnit = mpgInfo.isMPGe ? 'mi (est.)' : 'mi';

  // Range bar — fill % is adjusted / base.
  const fillPct = range.baseRange > 0
    ? Math.max(0, Math.min(100, (range.adjustedRange / range.baseRange) * 100))
    : 0;
  document.getElementById('pl-range-fill').style.width = `${fillPct}%`;
  document.getElementById('pl-range-tick').style.left = `${fillPct}%`;
  document.getElementById('pl-range-actual').textContent =
    `${Math.round(range.adjustedRange).toLocaleString()} ${distUnit} Actual`;
  document.getElementById('pl-range-max').textContent =
    `${Math.round(range.baseRange).toLocaleString()} ${distUnit} Max`;

  document.getElementById('pl-range-summary').innerHTML =
    `${mpgInfo.mpg.toFixed(1)} ${unit} base &nbsp;→&nbsp; ${range.adjustedMpg.toFixed(2)} ${unit} loaded &nbsp;·&nbsp; ` +
    `<b class="${lostMiles > 0 ? 'warn' : ''}">−${lostMiles.toFixed(1)} ${distUnit}</b> · ${powertrainCategory} · ${drivetrain}`;

  // Cost analysis — slider-controlled trip @ national avg gas price.
  const miles = clamp(tripMiles, MIN_TRIP_MILES, MAX_TRIP_MILES);
  const price = DEFAULT_GAS_PRICE;
  const emptyCost = calcTripCost(mpgInfo.mpg, miles, price);
  const loadedCost = calcTripCost(range.adjustedMpg, miles, price);
  const penaltyCost = loadedCost - emptyCost;
  const emptyGal = miles / mpgInfo.mpg;
  const loadedGal = range.adjustedMpg > 0 ? miles / range.adjustedMpg : 0;
  const tanksEmpty = emptyGal / tankGal;
  const tanksLoaded = loadedGal / tankGal;

  document.getElementById('pl-cost-title').textContent =
    `Estimated Fuel Cost · ${miles.toLocaleString()} mi @ $${price.toFixed(2)}/gal`;
  document.getElementById('pl-cost-sub').textContent = mpgInfo.isMPGe
    ? `EV approximation using MPGe — actual cost depends on local kWh pricing.`
    : `Plan your trip with the slider above. ${tanksEmpty.toFixed(1)} tank${tanksEmpty>=1.5?'s':''} empty · ${tanksLoaded.toFixed(1)} tank${tanksLoaded>=1.5?'s':''} loaded.`;

  document.getElementById('pl-cost-empty').textContent = `$${emptyCost.toFixed(2)}`;
  document.getElementById('pl-cost-empty-foot').textContent =
    `${emptyGal.toFixed(1)} gal · ${mpgInfo.mpg.toFixed(1)} ${unit} base`;
  document.getElementById('pl-cost-loaded').textContent = `$${loadedCost.toFixed(2)}`;
  document.getElementById('pl-cost-loaded-foot').textContent =
    `${loadedGal.toFixed(1)} gal · ${range.adjustedMpg.toFixed(2)} ${unit} adj.`;
  document.getElementById('pl-cost-penalty').textContent =
    `${penaltyCost >= 0 ? '+' : ''}$${penaltyCost.toFixed(2)}`;
  document.getElementById('pl-cost-penalty-foot').textContent =
    `+${(loadedGal - emptyGal).toFixed(2)} gal-eq · −${range.penaltyPct.toFixed(2)}% ${mpgInfo.isMPGe ? 'range' : 'MPG'}`;

  // Transparent math note — every number the user can verify by hand.
  const note = mpgInfo.isMPGe
    ? `<b>${state.make} ${state.model}</b> · ${subType} · ${drivetrain} · ${transmission}. ` +
      `Payload math: ${Math.round(totalWeight)} lb × ${(payloadCoeff * 100).toFixed(1)}% per 100 lb = <b>${range.penaltyPct.toFixed(2)}% range loss</b>. ` +
      `MPGe figures are gasoline-equivalent; gas-price comparison is illustrative for an ICE benchmark only.`
    : `<b>${state.make} ${state.model}</b> · ${subType} · ${drivetrain} · ${transmission} · curb ${curbLb.toLocaleString()} lb · ${tankGal} gal tank. ` +
      `Payload math: ${Math.round(totalWeight)} lb × ${(payloadCoeff * 100).toFixed(1)}% per 100 lb (${powertrainCategory}) = <b>${range.penaltyPct.toFixed(2)}% MPG loss</b>.`;
  document.getElementById('pl-cost-note').innerHTML = note;
}

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

// ===== WEIGHT OVERRIDE + TRIP-SLIDER LISTENERS =====
function attachPayloadControls() {
  const wIn = document.getElementById('pl-weight-input');
  const wReset = document.getElementById('pl-weight-reset');
  const tSlider = document.getElementById('pl-trip-slider');
  const tInput = document.getElementById('pl-trip-input');

  wIn.addEventListener('input', () => {
    const raw = wIn.value.trim();
    if (raw === '') { weightOverrideLb = null; }
    else {
      const v = Number(raw);
      weightOverrideLb = Number.isFinite(v) && v >= 0 ? Math.min(v, 10000) : null;
    }
    schedulePayloadRefresh();
  });
  wReset.addEventListener('click', () => {
    weightOverrideLb = null;
    wIn.value = '';
    schedulePayloadRefresh();
  });

  function setMiles(v) {
    tripMiles = clamp(Math.round(v), MIN_TRIP_MILES, MAX_TRIP_MILES);
    tSlider.value = tripMiles;
    tInput.value = tripMiles;
    schedulePayloadRefresh();
  }
  tSlider.addEventListener('input', () => setMiles(Number(tSlider.value)));
  tInput.addEventListener('input', () => {
    const v = Number(tInput.value);
    if (Number.isFinite(v)) setMiles(v);
  });
}

buildItemsGrid(); buildMakeSelect(); buildPassengerGrid(); attachPayloadControls();

</script>
