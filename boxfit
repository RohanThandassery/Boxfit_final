<style>
  /* === BASE RESET & VARIABLES === */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --orange: #F96302; --orange-dim: #c24d00;
    --bg: #0d0d0d; --surface: #181818; --surface2: #222;
    --border: #2e2e2e; --text: #e8e0d5; --muted: #777;
    --red: #ff3333; --green: #22c55e;
    --blue: #3b82f6; --purple: #8b5cf6;
    --mono: 'DM Mono', monospace; --display: 'Bebas Neue', sans-serif; --body: 'DM Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--text); font-family: var(--body); min-height: 100vh; overflow-x: hidden; }

  body::before {
    content: ''; position: fixed; inset: 0;
    background-image: linear-gradient(rgba(249,99,2,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(249,99,2,0.03) 1px, transparent 1px);
    background-size: 40px 40px; pointer-events: none; z-index: 0;
  }

  /* === HEADER === */
  header { position: relative; z-index: 10; background: #0d0d0d; border-bottom: 1px solid var(--border); padding: 0 2rem; display: flex; align-items: center; height: 64px; }
  .logo { font-family: var(--display); font-size: 2.2rem; color: var(--orange); letter-spacing: 0.05em; line-height: 1; }
  .nav-links { margin-left: auto; display: flex; gap: 2rem; }
  .nav-links button { background: none; border: none; font-family: var(--mono); font-size: 0.75rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: color 0.2s; }
  .nav-links button:hover { color: var(--text); }
  .nav-links button.active { color: var(--orange); border-bottom: 2px solid var(--orange); padding-bottom: 4px; }

  main { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 3rem 2rem 6rem; }

  /* === PAGES === */
  #page-calc, #page-sources { animation: fadeIn 0.3s ease; }
  #page-sources { display: none; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  /* === HERO === */
  .hero { margin-bottom: 3.5rem; }
  .hero h1 { font-family: var(--display); font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 0.95; letter-spacing: 0.02em; text-transform: uppercase; }
  .hero h1 span { color: var(--orange); }
  .hero p { margin-top: 1rem; color: var(--muted); font-size: 0.9rem; letter-spacing: 0.03em; max-width: 650px; line-height: 1.6; }

  /* === PANELS & LABELS === */
  .step-label { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; position: relative; }
  .step-num { font-family: var(--mono); font-size: 0.65rem; color: var(--orange); background: rgba(249,99,2,0.1); border: 1px solid rgba(249,99,2,0.3); width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .step-title { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }

  .loadout-status-badge { margin-left: auto; padding: 4px 10px; font-family: var(--mono); font-size: 0.7rem; font-weight: bold; border-radius: 4px; text-transform: uppercase; display: none; }
  .badge-neutral { background: var(--surface2); color: var(--muted); border: 1px dashed var(--muted); }
  .badge-fit { background: rgba(34, 197, 94, 0.15); color: var(--green); border: 1px solid var(--green); }
  .badge-over { background: rgba(255, 51, 51, 0.15); color: var(--red); border: 1px solid var(--red); }
  .badge-spatial { background: rgba(255, 176, 32, 0.14); color: #ffb020; border: 1px solid #ffb020; }

  .panel { background: var(--surface); border: 1px solid var(--border); padding: 1.75rem; margin-bottom: 1.5rem; position: relative; }
  .panel::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: var(--border); }
  .panel.active::before { background: var(--orange); }

  /* === ITEM GRID === */
  .item-group-title { font-family: var(--mono); font-size: 0.8rem; color: var(--text); letter-spacing: 0.1em; text-transform: uppercase; margin: 1.5rem 0 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
  .item-group-title:first-child { margin-top: 0; }
  .box-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.75rem; }
