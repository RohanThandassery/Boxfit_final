// ===== 3D BIN PACKER FOR ZONES =====
function packZone(zone, itemsToPack) {
  let res = 1; // 1 inch grid matches the stored integer-inch dimensions.
  let cols = Math.floor(zone.w / res);
  let rows = Math.floor(zone.d / res);
  
  if(cols <= 0 || rows <= 0) return { placed: [], remaining: itemsToPack };

  let heightMap = Array(cols).fill(0).map(()=>Array(rows).fill(zone.y));
  let placedInZone = [];
  let remainingItems = [];

  for (let item of itemsToPack) {
    let orientations = [
      {w: item.w, h: item.h, d: item.d}, {w: item.d, h: item.h, d: item.w}, 
      {w: item.w, h: item.d, d: item.h}, {w: item.h, h: item.w, d: item.d}, 
      {w: item.h, h: item.d, d: item.w}, {w: item.d, h: item.w, d: item.h}  
    ];

    let bestFit = null;
    let minBaseY = Infinity;
    const maxCeiling = zone.y + zone.h;

    for (let ori of orientations) {
      if (ori.h > zone.h) continue; 
      
      let gridW = Math.ceil(ori.w / res);
      let gridD = Math.ceil(ori.d / res);
      if (gridW > cols || gridD > rows) continue; 

      for (let x = 0; x <= cols - gridW; x++) {
        for (let z = 0; z <= rows - gridD; z++) {
          let localMaxY = 0;
          for (let ix=0; ix<gridW; ix++) {
            for (let iz=0; iz<gridD; iz++) {
              if (heightMap[x+ix] !== undefined && heightMap[x+ix][z+iz] > localMaxY) {
                localMaxY = heightMap[x+ix][z+iz];
              }
            }
          }

          if (localMaxY + ori.h <= maxCeiling && localMaxY < minBaseY) {
            minBaseY = localMaxY;
            bestFit = {x, z, ori, gridW, gridD, baseY: localMaxY};
            if (minBaseY === zone.y) break; 
          }
        }
        if (minBaseY === zone.y) break;
      }
    }

    if (bestFit) {
      for (let ix=0; ix<bestFit.gridW; ix++) {
        for (let iz=0; iz<bestFit.gridD; iz++) {
          if(heightMap[bestFit.x+ix]) heightMap[bestFit.x+ix][bestFit.z+iz] = bestFit.baseY + bestFit.ori.h;
        }
      }
      placedInZone.push({
        ...item,
        x: zone.x + (bestFit.x * res), 
        y: bestFit.baseY, 
        z: zone.z + (bestFit.z * res),
        packW: bestFit.ori.w, packH: bestFit.ori.h, packD: bestFit.ori.d,
        zoneName: zone.name
      });
    } else {
      remainingItems.push(item);
    }
  }

  return { placed: placedInZone, remaining: remainingItems };
}

// ANCHORED Z-COORDINATE SYSTEM & LOGIC
function processLoadout(carData, gen, passengers, loadoutSource = loadout) {
  const dims = gen.dimensions_inches;
  const carW = dims.width;
  const carH = dims.height;
  const trunkD = dims.depth_trunk;
  const totalFoldD = dims.depth_folded;
  const foldExtD = totalFoldD > trunkD ? totalFoldD - trunkD : 0; 
  const seatHeight = 14;
  const isTruck = carData.class === 'truck';
  const headrestByClass = { sedan: 36, hatchback: 37, suv: 39, truck: 39 };
  const rearHeadrestH = carData.rearHeadrestIn ?? headrestByClass[carData.class] ?? 38;
  const frontHeadrestH = carData.frontHeadrestIn ?? (rearHeadrestH + (isTruck ? 0 : 2));
  const midTunnelHump = carData.midTunnelIn ?? 6;
  const tunnelWidth = Math.max(0, carData.transmissionTunnelWidthIn ?? Math.min(carW / 3, Math.max(6, midTunnelHump)));
  const headrestSeatbackBuffer = Math.max(0, carData.headrestSeatbackBufferIn ?? 4);
  const isThreeRow = carData.seats >= 7 || /3-Row/i.test(carData.subType || '');
  const rearFootwellLegroom = carData.rearFootwellLegroomIn ?? (isThreeRow ? 38 : 36);
  const cabinH = isTruck ? rearHeadrestH : Math.max(carH, frontHeadrestH);
  const truckRearCabinD = isTruck ? 36 : 0;
  const truckRearSeatsAvail = isTruck ? Math.min(3, Math.max(0, carData.seats - 2)) : 0;

  const isFrontRightOcc = passengers >= 2;
  const rearPass = Math.max(0, passengers - 2);
  const rearSeatsAvail = carData.seats - 2;
  const hasFrontMiddle = isTruck && carData.seats >= 6;
  const isFrontMiddleOcc = hasFrontMiddle && passengers >= carData.seats;

  let lEmpty = rearPass < 1;
  let rEmpty = rearPass < 2;
  let cEmpty = rearPass < 3; 

  const foldBlocked = carData.foldable_rear && rearPass >= 2 && carData.seats <= 5;
  const isFolded = carData.foldable_rear && foldExtD > 0 && !foldBlocked;

  let zones = [];
  let trunkStart = foldExtD; 
  const sideFootW = Math.max(0, (carW - tunnelWidth) / 2);
  const midFootW = Math.max(0, tunnelWidth);
  const leftFootX = -carW / 2;
  const midFootX = -midFootW / 2;
  const rightFootX = carW / 2 - sideFootW;
  const canBridgeFootwell = tunnelWidth <= 0 || midTunnelHump <= 3;

  function rearSeatZoneH() { return Math.max(0, rearHeadrestH - seatHeight - headrestSeatbackBuffer); }
  function frontSeatZoneH() { return Math.max(0, frontHeadrestH - 14 - headrestSeatbackBuffer); }
  function bufferedSeatDepth(d) { return Math.max(0, d - headrestSeatbackBuffer); }
  function estimatedThirdRowFootwellDepth(maxD) {
    return Math.max(0, Math.min(maxD, 16, Math.max(10, rearFootwellLegroom * 0.38)));
  }
  function addFootwellZones(prefix, z, d, role, availability = { left: true, right: true, middle: true }, options = {}) {
    if (canBridgeFootwell && availability.left && availability.right) {
      zones.push({
        name: `${prefix} Footwell Bridge`,
        x: -carW/2, y: midTunnelHump, z, w: carW,
        h: Math.max(0, seatHeight-midTunnelHump), d,
        type: 'foot', isSeat: false, role,
        tunnelBridge: true,
        isFoldFootwell: !!options.isFoldFootwell,
        isThirdRowFootwell: !!options.isThirdRowFootwell
      });
      return;
    }
    if (availability.left) zones.push({ name: `${prefix} L Foot`, x: leftFootX, y: 0, z, w: sideFootW, h: seatHeight, d, type: 'foot', isSeat: false, role, tunnelLimited: true, isFoldFootwell: !!options.isFoldFootwell, isThirdRowFootwell: !!options.isThirdRowFootwell });
    if (availability.right) zones.push({ name: `${prefix} R Foot`, x: rightFootX, y: 0, z, w: sideFootW, h: seatHeight, d, type: 'foot', isSeat: false, role, tunnelLimited: true, isFoldFootwell: !!options.isFoldFootwell, isThirdRowFootwell: !!options.isThirdRowFootwell });
    if (availability.middle && midFootW > 0) zones.push({ name: `${prefix} Mid Tunnel`, x: midFootX, y: midTunnelHump, z, w: midFootW, h: Math.max(0, seatHeight-midTunnelHump), d, type: 'foot', isSeat: false, role, tunnelLimited: true, isFoldFootwell: !!options.isFoldFootwell, isThirdRowFootwell: !!options.isThirdRowFootwell });
  }
  function addThirdRowFootwellBelowDeck(foldStartZ, activeFoldD, firstFootwellD) {
    if (!isThreeRow) return;
    const thirdFootD = estimatedThirdRowFootwellDepth(activeFoldD);
    const minGap = 4;
    if (thirdFootD <= 0 || activeFoldD < firstFootwellD + thirdFootD + minGap) return;
    const rearwardStart = foldStartZ + Math.min(
      activeFoldD - thirdFootD,
      Math.max(firstFootwellD + minGap, activeFoldD * 0.50)
    );
    addFootwellZones('Third Row Below Deck', rearwardStart, thirdFootD, 'fold', { left: true, right: true, middle: true }, { isFoldFootwell: true, isThirdRowFootwell: true });
  }

  // 1. TRUNK
  zones.push({ name: isTruck ? 'Pickup Bed' : 'Trunk', x: -carW/2, y: 0, z: trunkStart, w: carW, h: carH, d: trunkD, type: 'cargo', isSeat: false, role: 'trunk' });

  // 2. REAR CABIN (Folded OR Seats)
  if (isTruck && truckRearSeatsAvail > 0) {
    let rFootD = 16;
    let rSeatD = truckRearCabinD - rFootD;
    let zFoot = -truckRearCabinD;
    let zSeat = zFoot + rFootD;

    if (lEmpty) {
        zones.push({ name: 'Rear Cab L Seat', x: -carW/2, y: seatHeight, z: zSeat, w: carW/3, h: rearSeatZoneH(), d: bufferedSeatDepth(rSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'rear' });
    }
    if (rEmpty) {
        zones.push({ name: 'Rear Cab R Seat', x: carW/6, y: seatHeight, z: zSeat, w: carW/3, h: rearSeatZoneH(), d: bufferedSeatDepth(rSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'rear' });
    }
    if (cEmpty && truckRearSeatsAvail >= 3) {
        zones.push({ name: 'Rear Cab Mid Seat', x: -carW/6, y: seatHeight, z: zSeat, w: carW/3, h: rearSeatZoneH(), d: bufferedSeatDepth(rSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'rear' });
    }
    addFootwellZones('Rear Cab', zFoot, rFootD, 'foot', { left: lEmpty, right: rEmpty, middle: cEmpty && truckRearSeatsAvail >= 3 });
  } else if (isFolded) {
    let activeFoldD = foldExtD * ((rearSeatsAvail - rearPass) / rearSeatsAvail);
    if (activeFoldD > 0) {
        const foldedFootwellD = Math.min(18, activeFoldD);
        const foldStartZ = trunkStart - activeFoldD;
        zones.push({ name: 'Folded Seat Deck', x: -carW/2, y: seatHeight, z: foldStartZ, w: carW, h: rearSeatZoneH(), d: bufferedSeatDepth(activeFoldD), type: 'cargo', isSeat: false, role: 'fold', isFoldDeck: true, headrestLimit: 'rear' });
        addFootwellZones('Folded Below Deck', foldStartZ, foldedFootwellD, 'fold', { left: true, right: true, middle: true }, { isFoldFootwell: true });
        addThirdRowFootwellBelowDeck(foldStartZ, activeFoldD, foldedFootwellD);
    }
  } else if (foldExtD > 0) {
    let rFootD = foldExtD * 0.4;
    let rSeatD = foldExtD * 0.6;
    let zFoot = trunkStart - foldExtD;
    let zSeat = zFoot + rFootD;

    if (lEmpty) {
        zones.push({ name: 'Rear L Seat', x: -carW/2, y: seatHeight, z: zSeat, w: carW/3, h: rearSeatZoneH(), d: bufferedSeatDepth(rSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'rear' });
    }
    if (rEmpty) {
        zones.push({ name: 'Rear R Seat', x: carW/6, y: seatHeight, z: zSeat, w: carW/3, h: rearSeatZoneH(), d: bufferedSeatDepth(rSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'rear' });
    }
    if (cEmpty && carData.seats >= 5) {
        zones.push({ name: 'Rear Mid Seat', x: -carW/6, y: seatHeight, z: zSeat, w: carW/3, h: rearSeatZoneH(), d: bufferedSeatDepth(rSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'rear' });
    }
    addFootwellZones('Rear', zFoot, rFootD, 'foot', { left: lEmpty, right: rEmpty, middle: cEmpty && carData.seats >= 5 });
  }

  // 3. FRONT CABIN 
  if (!isFrontRightOcc) {
    let fFootD = 16; let fSeatD = 20;
    let frontRearZ = isTruck ? -truckRearCabinD : 0;
    let frontRightX = hasFrontMiddle ? carW/6 : 0;
    let frontRightW = hasFrontMiddle ? carW/3 : carW/2;
    zones.push({ name: 'Front R Foot', x: frontRightX, y: 0, z: frontRearZ-fFootD-fSeatD, w: frontRightW, h: 14, d: fFootD, type: 'foot', isSeat: false, role: 'foot' });
    zones.push({ name: 'Front R Seat', x: frontRightX, y: 14, z: frontRearZ-fSeatD, w: frontRightW, h: frontSeatZoneH(), d: bufferedSeatDepth(fSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'front' });
  }
  if (hasFrontMiddle && passengers === 1 && !isFrontMiddleOcc) {
    let fFootD = 16; let fSeatD = 20;
    let frontRearZ = -truckRearCabinD;
    zones.push({ name: 'Front Mid Foot', x: midFootX, y: midTunnelHump, z: frontRearZ-fFootD-fSeatD, w: midFootW, h: Math.max(0, 14-midTunnelHump), d: fFootD, type: 'foot', isSeat: false, role: 'foot', tunnelLimited: true });
    zones.push({ name: 'Front Mid Seat', x: -carW/6, y: 14, z: frontRearZ-fSeatD, w: carW/3, h: frontSeatZoneH(), d: bufferedSeatDepth(fSeatD), type: 'seat', isSeat: true, role: 'seat', headrestLimit: 'front' });
  }

  let itemsToPack = [];
  for (let id in loadoutSource) {
    if (loadoutSource[id] > 0) {
      const itemDef = ITEMS.find(i => i.id === id);
      for (let i=0; i<loadoutSource[id]; i++) itemsToPack.push({...itemDef});
    }
  }
  itemsToPack.sort((a,b) => b.physVol - a.physVol);

  let finalPlaced = [];
  zones.sort((a,b) => {
    let pA = a.type === 'cargo' ? 1 : (a.type === 'foot' ? 2 : 3);
    let pB = b.type === 'cargo' ? 1 : (b.type === 'foot' ? 2 : 3);
    return pA - pB;
  });

  let currentItems = [...itemsToPack];
  for (let zone of zones) {
    let pRes = packZone(zone, currentItems);
    finalPlaced = finalPlaced.concat(pRes.placed);
    currentItems = pRes.remaining; 
  }

  let trunkVol = 0, foldVol = 0, seatVol = 0, footVol = 0;
  let trunkCapVol = 0, foldCapVol = 0, seatCapVol = 0, footCapVol = 0;
  
  zones.forEach(z => {
      let cap = (z.w * z.h * z.d) / 1728;
      if(z.role === 'trunk') trunkCapVol += cap;
      else if(z.role === 'fold') foldCapVol += cap;
      else if(z.role === 'seat') seatCapVol += cap;
      else if(z.role === 'foot') footCapVol += cap;
  });

  finalPlaced.forEach(i => {
    const zone = zones.find(z => z.name === i.zoneName);
    if(zone?.role === 'trunk') trunkVol += i.physVol;
    else if(zone?.role === 'fold') foldVol += i.physVol;
    else if(zone?.role === 'seat') seatVol += i.physVol;
    else if(zone?.role === 'foot') footVol += i.physVol;
  });

  return {
    carW, carH, cabinH, rearHeadrestH, frontHeadrestH, trunkD, totalD: trunkStart + trunkD,
    placed3D: finalPlaced, failedItems: currentItems, itemsPlaced: finalPlaced.length,
    zones: zones, 
    trunkUsedVol: trunkVol, foldUsedVol: foldVol, seatUsedVol: seatVol, footUsedVol: footVol,
    trunkCap: trunkCapVol, foldCap: foldCapVol, seatCap: seatCapVol, footCap: footCapVol,
    foldBlocked,
    isFolded,
    seatHeight,
    isTruck,
    isThreeRow,
    tunnelWidth,
    headrestSeatbackBuffer,
    thirdRowFootwellCount: zones.filter(z => z.isThirdRowFootwell).length,
    truckRearCabinD,
    cabBedDividerZ: isTruck ? trunkStart : null,
    requestedVol: itemsToPack.reduce((sum, item) => sum + item.physVol, 0)
  };
}

// ===== THREE.JS 3D RENDERER =====
let scene, camera, renderer, controls;
let container3D;
let webglUnavailable = false;
let drawSceneTimer = null;

function init3D() {
  container3D = document.getElementById('r-3d-canvas');
  if(!renderer) {
    scene = new THREE.Scene();
    let cw = container3D.clientWidth || 600;
    let ch = container3D.clientHeight || 400;
    
    camera = new THREE.PerspectiveCamera(50, cw / ch, 0.1, 1000);
    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(cw, ch);
    container3D.appendChild(renderer.domElement);

    if (typeof THREE.OrbitControls !== 'undefined') {
        controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
    }

    window.addEventListener('resize', () => {
      if(container3D.clientWidth > 0) {
        camera.aspect = container3D.clientWidth / container3D.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container3D.clientWidth, container3D.clientHeight);
      }
    });
    animate3D();
  } else {
    let cw = container3D.clientWidth || 600;
    let ch = container3D.clientHeight || 400;
    camera.aspect = cw / ch;
    camera.updateProjectionMatrix();
    renderer.setSize(cw, ch);
  }
}

function animate3D() {
  requestAnimationFrame(animate3D);
  if(controls) controls.update();
  renderer.render(scene, camera);
}

function disposeSceneObject(obj) {
  if (!obj) return;
  if (obj.geometry) obj.geometry.dispose();
  if (obj.material) {
    const materials = Array.isArray(obj.material) ? obj.material : [obj.material];
    materials.forEach(mat => {
      Object.values(mat).forEach(value => {
        if (value && typeof value.dispose === 'function') value.dispose();
      });
      mat.dispose();
    });
  }
}

function clearScene() {
  if (!scene) return;
  while (scene.children.length > 0) {
    const child = scene.children[0];
    scene.remove(child);
    child.traverse(disposeSceneObject);
  }
}

function drawScene(results) {
  try {
    if (webglUnavailable) return;
    if (typeof THREE === 'undefined') throw new Error("Three.js blocked or not loaded.");
    init3D();
    clearScene();
    
    scene.add(new THREE.AmbientLight(0xffffff, 0.8));
    const dirLight = new THREE.DirectionalLight(0xffffff, 0.5);
    dirLight.position.set(50, 100, 50);
    scene.add(dirLight);

    const offsetX = 0; 
    let minZ = Infinity, maxZ = -Infinity;
    let maxY = results.carH;
    results.zones.forEach(z => {
        if(z.z < minZ) minZ = z.z;
        if(z.z + z.d > maxZ) maxZ = z.z + z.d;
        if(z.y + z.h > maxY) maxY = z.y + z.h;
    });
    const centerZ = (minZ + maxZ) / 2;

    const matCargo = new THREE.LineDashedMaterial({ color: 0xffffff, opacity: 0.42, transparent: true, dashSize: 2, gapSize: 2, depthTest: false });
    const matSeat = new THREE.LineDashedMaterial({ color: 0x3b82f6, opacity: 0.5, transparent: true, dashSize: 2, gapSize: 2, depthTest: false });
    const matSolidCargo = new THREE.LineBasicMaterial({ color: 0xffffff, opacity: 0.16, transparent: true, depthTest: false });
    const matSolidSeat = new THREE.LineBasicMaterial({ color: 0x3b82f6, opacity: 0.18, transparent: true, depthTest: false });
    const matTruckDivider = new THREE.LineBasicMaterial({ color: 0xffb020, opacity: 0.85, transparent: true, depthTest: false });
    const matFoldDeck = new THREE.LineBasicMaterial({ color: 0xffb020, opacity: 0.7, transparent: true, depthTest: false });

    results.zones.forEach(z => {
      let zw = Math.max(1, z.w), zh = Math.max(1, z.h), zd = Math.max(1, z.d);
      let mat = z.type === 'cargo' ? matCargo : matSeat;
      let solidMat = z.type === 'cargo' ? matSolidCargo : matSolidSeat;
      let geo = new THREE.EdgesGeometry(new THREE.BoxGeometry(zw, zh, zd));
      let solid = new THREE.LineSegments(geo, solidMat);
      solid.position.set(offsetX + z.x + (zw/2), z.y + (zh/2), (z.z - centerZ) + (zd/2));
      solid.renderOrder = 1;
      scene.add(solid);
      let mesh = new THREE.LineSegments(geo, mat);
      mesh.computeLineDistances();
      mesh.position.set(offsetX + z.x + (zw/2), z.y + (zh/2), (z.z - centerZ) + (zd/2));
      mesh.renderOrder = 2;
      scene.add(mesh);

      if (z.isFoldDeck) {
        const y = z.y;
        const z0 = z.z - centerZ;
        const z1 = z.z + z.d - centerZ;
        const x0 = offsetX + z.x;
        const x1 = offsetX + z.x + z.w;
        const deckGeo = new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(x0, y, z0),
          new THREE.Vector3(x1, y, z0),
          new THREE.Vector3(x1, y, z1),
          new THREE.Vector3(x0, y, z1),
          new THREE.Vector3(x0, y, z0)
        ]);
        const deckLine = new THREE.Line(deckGeo, matFoldDeck);
        deckLine.renderOrder = 4;
        scene.add(deckLine);
      }
    });

    if (results.isTruck) {
      const dividerGeo = new THREE.BufferGeometry().setFromPoints([
        new THREE.Vector3(-results.carW/2, 0, results.cabBedDividerZ - centerZ),
        new THREE.Vector3(results.carW/2, 0, results.cabBedDividerZ - centerZ),
        new THREE.Vector3(results.carW/2, results.carH, results.cabBedDividerZ - centerZ),
        new THREE.Vector3(-results.carW/2, results.carH, results.cabBedDividerZ - centerZ),
        new THREE.Vector3(-results.carW/2, 0, results.cabBedDividerZ - centerZ)
      ]);
      const divider = new THREE.Line(dividerGeo, matTruckDivider);
      divider.renderOrder = 4;
      scene.add(divider);
    }

    const matBox = new THREE.MeshPhongMaterial({ color: 0xF96302, transparent: true, opacity: 0.85, shininess: 10 });
    const matLuggage = new THREE.MeshPhongMaterial({ color: 0x8b5cf6, transparent: true, opacity: 0.85, shininess: 10 });
    const matEdge = new THREE.LineBasicMaterial({ color: 0x000000 });

    results.placed3D.forEach(item => {
      let pw = Math.max(1, item.packW), ph = Math.max(1, item.packH), pd = Math.max(1, item.packD);
      const cx = offsetX + item.x + (pw/2);
      const cy = item.y + (ph/2);
      const cz = (item.z - centerZ) + (pd/2);

      const geo = new THREE.BoxGeometry(pw, ph, pd);
      const mesh = new THREE.Mesh(geo, item.type === 'luggage' ? matLuggage : matBox);
      mesh.position.set(cx, cy, cz);
      mesh.renderOrder = 3;
      scene.add(mesh);

      const edges = new THREE.LineSegments(new THREE.EdgesGeometry(geo), matEdge);
      edges.position.set(cx, cy, cz);
      edges.renderOrder = 5;
      scene.add(edges);
    });

    const maxDim = Math.max(results.carW, maxZ - minZ, maxY);
    camera.position.set(maxDim*1.2, maxDim*0.8, maxDim*1.2);
    
    if(controls) controls.target.set(0, maxY/2, 0);
    else camera.lookAt(0, maxY/2, 0);

  } catch(e) {
    webglUnavailable = true;
    console.warn("3D Engine Warning:", e);
    document.getElementById('r-3d-canvas').innerHTML = "<div style='color:var(--orange); font-family:var(--mono); text-align:center; padding-top:40px;'><br>3D VIEWER UNAVAILABLE<br><br><span style='font-size:0.7rem;color:#777;'>Please check your adblocker or internet connection,<br>as the 3D rendering scripts were blocked.</span></div>";
  }
}

