  .pass-btn .pass-label { font-family: var(--mono); font-size: 0.45rem; color: var(--muted); letter-spacing: 0.05em; line-height: 1; margin-top: 2px;}
  .pass-btn:hover:not(:disabled) { border-color: rgba(249,99,2,0.5); }
  .pass-btn.selected { border-color: var(--orange); background: rgba(249,99,2,0.07); }
  .pass-btn:disabled { opacity: 0.2; cursor: not-allowed; }

  /* === RESULTS DASHBOARD === */
  #results-panel { display: none; background: var(--surface); border: 1px solid var(--border); padding: 2rem 1.75rem; margin-bottom: 1.5rem; position: relative; }
  #results-panel.status-fit { border-color: var(--green); }
  #results-panel.status-fit::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--green); }
  #results-panel.status-over { border-color: var(--red); }
  #results-panel.status-over::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--red); }

  .results-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .results-car-name { font-family: var(--display); font-size: 1.5rem; letter-spacing: 0.05em; color: var(--text); line-height: 1.1; }
  .results-car-sub { font-family: var(--mono); font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; margin-top: 0.35rem; }

  /* Dashboard Split */
  .dashboard-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: 2.5rem; margin-bottom: 2rem; }
  @media (max-width: 900px) { .dashboard-grid { grid-template-columns: 1fr; } }

  .dashboard-left { display: flex; flex-direction: column; gap: 1.5rem; }
  .dashboard-right { display: flex; flex-direction: column; }

  .result-breakdown { display: flex; flex-direction: column; gap: 1.2rem; }
  .breakdown-row { display: flex; flex-direction: column; gap: 0.4rem; }
  .bar-header { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
  .breakdown-bar-wrap { width: 100%; height: 12px; background: var(--bg); border: 1px solid var(--border); overflow: hidden; border-radius: 2px; }
  .breakdown-bar { height: 100%; transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1); background: var(--orange); }
  .breakdown-bar-wrap.warn { border-color: #ffb020; box-shadow: 0 0 0 1px rgba(255,176,32,0.15); }
  .bar-seats { background: var(--blue); }
  .bar-foot { background: var(--purple); }

  /* 3D Visualizer */
  .visualizer-wrapper { width: 100%; height: 400px; background: #111; border: 1px solid var(--border); border-radius: 4px; position: relative; overflow: hidden; cursor: grab; }
  .visualizer-wrapper:active { cursor: grabbing; }
  .vis-label { position: absolute; top: 10px; left: 10px; font-family: var(--mono); font-size: 0.6rem; color: var(--orange); letter-spacing: 0.15em; background: rgba(0,0,0,0.8); padding: 6px 10px; border-radius: 4px; pointer-events: none; z-index: 10;}
  .vis-legend { position: absolute; bottom: 10px; right: 10px; display: flex; flex-direction: column; gap: 4px; background: rgba(0,0,0,0.8); padding: 8px; border-radius: 4px; pointer-events: none; }
  .leg-item { display: flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 0.55rem; color: #ccc; text-transform: uppercase; }
  .leg-color { width: 10px; height: 10px; border-radius: 2px; }
  #r-3d-canvas { width: 100%; height: 100%; display:flex; align-items:center; justify-content:center;}

  /* Room to Spare Section */
  .spare-room-container { background: var(--bg); border: 1px solid var(--border); padding: 1rem; border-radius: 4px; }
  .spare-room-title { font-family: var(--display); font-size: 1.2rem; color: var(--green); margin-bottom: 0.5rem; letter-spacing: 0.05em; }
  .spare-room-desc { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); margin-bottom: 1rem; line-height: 1.5;}
  .spare-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .spare-chip { background: var(--surface2); border: 1px solid var(--border); padding: 6px 10px; border-radius: 4px; font-family: var(--mono); font-size: 0.75rem; color: var(--muted); }
  .spare-chip b { color: var(--text); font-weight: normal; }
  .fit-alert { background: rgba(255,176,32,0.08); border: 1px solid rgba(255,176,32,0.45); padding: 1rem; border-radius: 4px; margin-bottom: 1rem; }
  .fit-alert-title { font-family: var(--display); font-size: 1.2rem; color: #ffb020; letter-spacing: 0.05em; margin-bottom: 0.35rem; }
  .fit-alert-copy { font-family: var(--mono); font-size: 0.72rem; color: var(--text); line-height: 1.5; }

  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-bottom: 1.25rem; }
  .stat-cell { background: var(--surface2); padding: 1rem; }
  .stat-cell-label { font-family: var(--mono); font-size: 0.58rem; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.35rem; }
  .stat-cell-val { font-family: var(--mono); font-size: 0.95rem; color: var(--text); }

  .notes-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.5rem;}
  .notes-list li { font-size: 0.8rem; color: var(--muted); display: flex; align-items: flex-start; gap: 0.6rem; line-height: 1.5; }
  .notes-list li::before { content: '—'; color: var(--orange); flex-shrink: 0; font-family: var(--mono); }

  .select-prompt { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); letter-spacing: 0.1em; padding: 2rem; text-align: center; border: 1px dashed var(--border); margin-bottom: 1.5rem; }

  /* OVERLAY FOR WHEN DATA IS MISSING */
  #awaiting-overlay { position: absolute; inset: 0; background: rgba(24,24,24,0.95); z-index: 20; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
  .awaiting-text { font-family: var(--mono); font-size: 1rem; color: var(--orange); letter-spacing: 0.1em; border: 1px dashed var(--border); padding: 2rem; background: var(--bg); }

  /* === SOURCES TABLE === */
  .table-wrap { width: 100%; overflow-x: auto; background: var(--surface); border: 1px solid var(--border); margin-bottom: 2rem;}
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; text-align: left; }
  th, td { padding: 1rem; border-bottom: 1px solid var(--border); }
  th { font-family: var(--mono); font-size: 0.7rem; color: var(--orange); letter-spacing: 0.1em; text-transform: uppercase; background: var(--surface2); }
  tr:last-child td { border-bottom: none; }
  td { color: var(--text); line-height: 1.4; }
  td.muted { color: var(--muted); font-family: var(--mono); font-size: 0.75rem; }

  footer { text-align: center; padding: 2rem; font-family: var(--mono); font-size: 0.62rem; color: #555; letter-spacing: 0.1em; border-top: 1px solid var(--border); margin-top: 4rem; }

  /* === PAYLOAD & RANGE IMPACT SECTION === */
  .payload-section { margin-top: 2rem; padding-top: 1.75rem; border-top: 1px solid var(--border); }
  .payload-section-title { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--orange); margin-bottom: 1.25rem; }
  .payload-section-title span { color: var(--muted); margin-left: 0.5rem; letter-spacing: 0.1em; }

  .payload-weight-card {
    display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    background: var(--bg); border: 1px solid var(--border); padding: 1.1rem 1.25rem; border-radius: 4px; margin-bottom: 1.25rem;
  }
  .payload-weight-label { font-family: var(--mono); font-size: 0.65rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; }
  .payload-weight-val { font-family: var(--display); font-size: 2.4rem; color: var(--orange); letter-spacing: 0.04em; line-height: 1; }
  .payload-weight-val small { font-family: var(--mono); font-size: 0.7rem; color: var(--muted); margin-left: 0.4rem; letter-spacing: 0.1em; }
  .payload-weight-breakdown { font-family: var(--mono); font-size: 0.65rem; color: var(--muted); letter-spacing: 0.06em; }
  .payload-weight-breakdown b { color: var(--text); font-weight: 500; }

  .range-card {
    background: var(--bg); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px; margin-bottom: 1.25rem;
  }
  .range-header { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 0.85rem; font-family: var(--mono); }
  .range-title { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text); }
  .range-summary { font-size: 0.65rem; letter-spacing: 0.1em; color: var(--muted); }
  .range-summary b.warn { color: var(--red); }

  .range-bar-shell {
    position: relative; width: 100%; height: 28px; background: var(--surface2); border: 1px solid var(--border);
    border-radius: 4px; overflow: hidden;
  }
  .range-bar-fill {
    position: absolute; inset: 0 auto 0 0; background: linear-gradient(90deg, var(--orange) 0%, #ffae5c 100%);
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .range-bar-tick {
    position: absolute; top: 0; bottom: 0; width: 2px; background: rgba(255,255,255,0.55);
    box-shadow: 0 0 6px rgba(0,0,0,0.5);
  }
  .range-bar-labels { display: flex; justify-content: space-between; margin-top: 0.5rem; font-family: var(--mono); font-size: 0.62rem; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }
  .range-bar-labels b { color: var(--text); font-weight: 500; }
  .range-bar-labels .range-actual { color: var(--orange); }

  .cost-block { background: var(--bg); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px; }
  .cost-block-title { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text); margin-bottom: 0.25rem; }
  .cost-block-sub { font-family: var(--mono); font-size: 0.62rem; color: var(--muted); letter-spacing: 0.08em; margin-bottom: 1rem; }
  .cost-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: var(--border); border: 1px solid var(--border); }
  @media (max-width: 640px) { .cost-grid { grid-template-columns: 1fr; } }
  .cost-cell { background: var(--surface2); padding: 1rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .cost-cell-label { font-family: var(--mono); font-size: 0.58rem; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; }
  .cost-cell-val { font-family: var(--display); font-size: 1.6rem; letter-spacing: 0.04em; color: var(--text); line-height: 1; }
  .cost-cell-val.empty { color: var(--green); }
  .cost-cell-val.loaded { color: var(--orange); }
  .cost-cell-val.penalty { color: var(--red); }
  .cost-cell-foot { font-family: var(--mono); font-size: 0.58rem; color: var(--muted); letter-spacing: 0.06em; }
  .cost-note { margin-top: 0.85rem; font-family: var(--mono); font-size: 0.6rem; color: var(--muted); letter-spacing: 0.06em; line-height: 1.5; }
  .cost-note b { color: var(--text); font-weight: 500; }
  .ev-note { font-family: var(--mono); font-size: 0.65rem; color: #ffb020; letter-spacing: 0.08em; line-height: 1.5; }

  /* === WEIGHT OVERRIDE === */
  .pwc-main { display: flex; flex-direction: column; gap: 0.5rem; min-width: 0; }
  .pwc-mode { font-family: var(--mono); font-size: 0.55rem; letter-spacing: 0.1em; color: var(--muted); margin-left: 0.4rem; text-transform: uppercase; }
  .pwc-mode.custom { color: var(--orange); }
  .pwc-override { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.35rem; font-family: var(--mono); font-size: 0.7rem; color: var(--muted); letter-spacing: 0.06em; }
  .pwc-override label { text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.62rem; color: var(--muted); }
  .pwc-override input[type="number"] {
